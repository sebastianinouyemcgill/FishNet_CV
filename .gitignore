# =============================================================================
# src/ layout (all .py under src/ is committed — nothing below is gitignored)
#
# Production pipeline:
#   config, paths, dataset, masks, evaluation, submission
#   methods/geometric, methods/calibration/marker, methods/regression, methods/estimator
#   measurement/, calibration/marker, models/, pipelines/base|baseline|regression_inference
#   experiments/, colab_bootstrap, visualization/, notebooks/
#
# Experimental (in repo, disabled by default in config.yaml):
#   calibration/grid_auto, depth/, pipelines/advanced*, keypoints/, experimental/
# =============================================================================
